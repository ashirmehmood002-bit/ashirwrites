# ============================================================
# ASHER WRITES — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# MongoDB Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/asher-writes?retryWrites=true&w=majority

# JWT Secret — use a long, random string (min 32 chars)
JWT_SECRET=replace_with_a_very_long_random_secret_string_at_least_32_chars

# JWT Expiry
JWT_EXPIRES_IN=7d

# Admin credentials (used only during initial seed)
ADMIN_USERNAME=asher
ADMIN_PASSWORD=AsherAdmin@2024!

# Server port (Vercel ignores this; used for local dev)
PORT=3000

# Node environment
NODE_ENV=production
